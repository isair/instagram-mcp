# Instagram MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Instagram credentials
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# Optional: Session file path (defaults to .instagram_session)
# Run `instagram-mcp-login` first to authenticate and save session
# INSTAGRAM_SESSION_FILE=.instagram_session

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# E2E test account (second bot for testing DM flows)
# TEST_USERNAME=test_bot_username
# TEST_PASSWORD=test_bot_password
